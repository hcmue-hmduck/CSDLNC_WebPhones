        renderPagination() {
            const prevBtn = document.getElementById('prevPage');
            const nextBtn = document.getElementById('nextPage');
            const numbersContainer = document.getElementById('productPaginationNumbers');

            if (!prevBtn || !nextBtn || !numbersContainer) return;

            // Cập nhật trạng thái nút prev/next
            prevBtn.disabled = this.currentPage === 1;
            nextBtn.disabled = this.currentPage === this.totalPages || this.totalPages === 0;

            // Tạo các số trang
            numbersContainer.innerHTML = '';
            const maxVisiblePages = 5;
            let startPage = Math.max(1, this.currentPage - Math.floor(maxVisiblePages / 2));
            let endPage = Math.min(this.totalPages, startPage + maxVisiblePages - 1);

            if (endPage - startPage < maxVisiblePages - 1) {
                startPage = Math.max(1, endPage - maxVisiblePages + 1);
            }

            // Nút trang đầu và dấu ...
            if (startPage > 1) {
                const firstBtn = this.createPageButton(1);
                numbersContainer.appendChild(firstBtn);
                if (startPage > 2) {
                    const dots = document.createElement('span');
                    dots.className = 'pagination-dots';
                    dots.textContent = '...';
                    numbersContainer.appendChild(dots);
                }
            }

            // Các trang ở giữa
            for (let i = startPage; i <= endPage; i++) {
                const pageBtn = this.createPageButton(i);
                numbersContainer.appendChild(pageBtn);
            }

            // Dấu ... và trang cuối
            if (endPage < this.totalPages) {
                if (endPage < this.totalPages - 1) {
                    const dots = document.createElement('span');
                    dots.className = 'pagination-dots';
                    dots.textContent = '...';
                    numbersContainer.appendChild(dots);
                }
                const lastBtn = this.createPageButton(this.totalPages);
                numbersContainer.appendChild(lastBtn);
            }
        }

        createPageButton(pageNumber) {
            const btn = document.createElement('button');
            btn.className = 'pagination-number-btn';
            if (pageNumber === this.currentPage) {
                btn.classList.add('active');
            }
            btn.textContent = pageNumber;
            btn.onclick = () => this.goToPage(pageNumber);
            return btn;
        }

        goToPage(page) {
            if (page < 1 || page > this.totalPages) return;
            this.currentPage = page;
            this.renderProductsTable();
        }


        async refreshProducts() {
            const refreshBtn = document.getElementById('refreshBtn');
            const originalHtml = refreshBtn?.innerHTML || '<i class="fas fa-sync-alt"></i> Làm mới';
            
            try {
                console.log('🔄 Refreshing products data...');
                
                // 🆕 QUAN TRỌNG: Đóng tất cả modal đang mở trước khi refresh
                this.closeAllModals();
                
                // Set trạng thái loading
                if (refreshBtn) {
                    refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang làm mới...';
                    refreshBtn.disabled = true;
                }
                
                // Reset và reload
                this.clearFilters();
                this.showLoading(true);
                await this.loadProducts();
                this.renderProductsTable();
                this.filterProducts();
                this.updateStats();
                
                console.log('✅ Products data refreshed successfully');
                
            } catch (error) {
                console.error('❌ Error refreshing products:', error);
                this.showError('Không thể làm mới dữ liệu: ' + error.message);
            } finally {
                // Reset nút refresh
                if (refreshBtn) {
                    refreshBtn.innerHTML = originalHtml;
                    refreshBtn.disabled = false;
                }
                
                this.showLoading(false);
            }
        }

        // 🆕 Thêm phương thức đóng tất cả modal
        closeAllModals() {
            // Đóng modal sản phẩm
            const productModal = document.getElementById('productModal');
            if (productModal) {
                const modalInstance = bootstrap.Modal.getInstance(productModal);
                if (modalInstance) {
                    modalInstance.hide();
                }
            }
            
            console.log('🚪 Đã đóng modal sản phẩm');
        }

        // Phương thức reset nút refresh
        resetRefreshButton(refreshBtn, originalHtml) {
            if (refreshBtn) {
                // Reset ngay lập tức, không cần setTimeout
                refreshBtn.innerHTML = originalHtml || '<i class="fas fa-sync-alt"></i> Làm mới';
                refreshBtn.disabled = false;
                
                console.log('🔄 Reset refresh button completed');
            }
        }




        bindEvents() {
            // Product Management
            const addProductBtn = document.getElementById('addProductBtn');
            if (addProductBtn) {
                console.log('✅ addProductBtn found, binding click event');
                addProductBtn.addEventListener('click', () => {
                    console.log('🔵 addProductBtn clicked!');
                    this.openProductModal();
                });
            } else {
                console.error('❌ addProductBtn NOT FOUND');
            }
            
            document.getElementById('addProductEmptyBtn')?.addEventListener('click', () => this.openProductModal());
            document.getElementById('saveProductBtn')?.addEventListener('click', () => this.saveProduct());
            document.getElementById('refreshBtn')?.addEventListener('click', () => this.refreshProducts());

            // Pagination
            document.getElementById('prevPage')?.addEventListener('click', () => this.goToPage(this.currentPage - 1));
            document.getElementById('nextPage')?.addEventListener('click', () => this.goToPage(this.currentPage + 1));

            // Search and Filter - Auto search/filter
            document.getElementById('searchInput')?.addEventListener('input',
                Utils.debounce(() => this.filterProducts(), 300)
            );
            document.getElementById('statusFilter')?.addEventListener('change', () => this.filterProducts());
            document.getElementById('categoryFilter')?.addEventListener('change', () => this.filterProducts());
            document.getElementById('brandFilter')?.addEventListener('change', () => this.filterProducts());
            document.getElementById('clearFilters')?.addEventListener('click', () => this.clearFilters());

            // Event Delegation for Table
            document.addEventListener('click', (e) => {
                if (e.target.closest('.btn-edit')) {
                    this.handleEditProduct(e.target.closest('.btn-edit'));
                }
                if (e.target.closest('.btn-delete-product')) {
                    this.handleDeleteProduct(e.target.closest('.btn-delete-product'));
                }
                if (e.target.closest('.btn-toggle-status')) {
                    this.handleToggleStatus(e.target.closest('.btn-toggle-status'));
                }
            });

            // Technical Specifications Management
            // Select All Checkbox
            document.getElementById('selectAll')?.addEventListener('change', (e) => {
                this.toggleSelectAll(e.target.checked);
            });
        }

        setupImagePreview() {
            const imageInput = document.getElementById('productImage');
            if (imageInput) {
                imageInput.addEventListener('input', Utils.debounce((e) => {
                    this.updateImagePreview(e.target.value);
                }, 500));
            }
        }

        updateImagePreview(imageUrl) {
            const preview = document.getElementById('imagePreview');
            if (!preview) return;

            preview.innerHTML = '';

            if (imageUrl && imageUrl.trim() !== '') {
                Utils.validateImageUrl(imageUrl).then(isValid => {
                    if (isValid) {
                        const img = document.createElement('img');
                        img.src = imageUrl;
                        img.alt = 'Product Preview';
                        preview.appendChild(img);
                        preview.classList.add('has-image');
                    } else {
                        this.showImageError(preview);
                    }
                });
            } else {
                this.showImagePlaceholder(preview);
            }
        }

        showImagePlaceholder(preview) {
            preview.innerHTML = `
                <div class="preview-placeholder">
                <i class="fas fa-image"></i>
                <span>Preview hình ảnh</span>
                </div>
            `;
            preview.classList.remove('has-image');
        }

        showImageError(preview) {
            preview.innerHTML = `
                <div class="preview-placeholder">
                <i class="fas fa-exclamation-triangle"></i>
                <span>Không thể tải ảnh</span>
                </div>
            `;
            preview.classList.remove('has-image');
        }

        updateStats() {
            const total = this.products.length;
            const active = this.products.filter(p => p.trang_thai == 1).length;
            const inactive = this.products.filter(p => p.trang_thai == 0).length;
            
            // Tính tổng doanh số (giá bán × số lượng đã bán)
            const totalRevenue = this.products.reduce((sum, p) => {
                const soldQuantity = p.luot_ban || 0;
                const price = p.gia_ban || 0;
                return sum + (soldQuantity * price);
            }, 0);

            console.log('📊 Stats:', { total, active, inactive, totalRevenue });

            document.getElementById('totalProducts').textContent = total;
            document.getElementById('countActive').textContent = active;
            document.getElementById('countInactive').textContent = inactive;
            document.getElementById('totalRevenue').textContent = Utils.formatCompactCurrency(totalRevenue);
        }

        updateStatsWithCounts(total, active, inactive, totalRevenue) {
            document.getElementById('totalProducts').textContent = total;
            document.getElementById('countActive').textContent = active;
            document.getElementById('countInactive').textContent = inactive;
            document.getElementById('totalRevenue').textContent = Utils.formatCompactCurrency(totalRevenue);
        }

        filterProducts() {
            const searchTerm = document.getElementById('searchInput')?.value.toLowerCase() || '';
            const statusFilter = document.getElementById('statusFilter')?.value || '';
            const categoryFilter = document.getElementById('categoryFilter')?.value || '';
            const brandFilter = document.getElementById('brandFilter')?.value || '';

            const rows = document.querySelectorAll('#productsTable tbody tr');
            let visibleCount = 0;
            let visibleActive = 0;
            let visibleInactive = 0;
            let visibleRevenue = 0;

            rows.forEach((row, index) => {
                const name = row.querySelector('.product-name')?.textContent.toLowerCase() || '';
                const sku = row.querySelector('.product-sku')?.textContent.toLowerCase() || '';
                const status = row.getAttribute('data-status') || '';
                const category = row.getAttribute('data-category') || '';
                const brand = row.getAttribute('data-brand') || '';
                const productId = row.getAttribute('data-id') || '';

                const matchesSearch = name.includes(searchTerm) || sku.includes(searchTerm);
                const matchesStatus = !statusFilter || status === statusFilter;
                const matchesCategory = !categoryFilter || category === categoryFilter;
                const matchesBrand = !brandFilter || brand === brandFilter;

                // Status filter only affects visual styling, not visibility
                if (matchesSearch && matchesCategory && matchesBrand) {
                    row.style.display = '';
                    visibleCount++;
                    
                    // Apply visual styling based on status filter
                    if (statusFilter && !matchesStatus) {
                        row.style.opacity = '0.4';
                        row.style.backgroundColor = '#f9fafb';
                    } else {
                        row.style.opacity = '1';
                        row.style.backgroundColor = '';
                    }
                    
                    // Đếm stats cho sản phẩm hiển thị
                    if (status === '1') visibleActive++;
                    if (status === '0') visibleInactive++;
                    
                    // Tính doanh số của sản phẩm này
                    const product = this.products.find(p => p.id == productId);
                    if (product) {
                        const soldQuantity = product.luot_ban || 0;
                        const price = product.gia_ban || 0;
                        visibleRevenue += (soldQuantity * price);
                    }
                } else {
                    row.style.display = 'none';
                    row.style.opacity = '1';
                    row.style.backgroundColor = '';
                }
            });

            console.log('🔍 Filter Stats:', { visibleCount, visibleActive, visibleInactive, visibleRevenue });

            this.toggleEmptyState(visibleCount === 0);
            this.updateTableInfo(visibleCount);
            
            // KHÔNG cập nhật stats khi filter - giữ nguyên stats tổng thể
            // Stats luôn hiển thị thông tin tổng thể từ this.products
        }

        clearFilters() {
            const searchInput = document.getElementById('searchInput');
            const statusFilter = document.getElementById('statusFilter');
            const categoryFilter = document.getElementById('categoryFilter');
            const brandFilter = document.getElementById('brandFilter');

            if (searchInput) searchInput.value = '';
            if (statusFilter) statusFilter.value = '';
            if (categoryFilter) categoryFilter.value = '';
            if (brandFilter) brandFilter.value = '';

            console.log('🧹 Đã xóa tất cả bộ lọc');
            
            // Render lại dữ liệu gốc
            this.filterProducts();
        }

        toggleEmptyState(show) {
            const emptyState = document.getElementById('emptyState');
            const tableContainer = document.querySelector('.table-container');

            if (emptyState && tableContainer) {
                emptyState.style.display = show ? 'flex' : 'none';
                tableContainer.style.display = show ? 'none' : 'block';
            }
        }

        showLoading(show) {
            const loadingState = document.getElementById('loadingState');
            const tableContainer = document.querySelector('.table-container');
            const emptyState = document.getElementById('emptyState');

            if (loadingState && tableContainer && emptyState) {
                if (show) {
                    loadingState.style.display = 'flex';
                    tableContainer.style.display = 'none';
                    emptyState.style.display = 'none';
                } else {
                    loadingState.style.display = 'none';
                    tableContainer.style.display = 'block';
                    
                    // Kiểm tra xem có sản phẩm nào không để hiển thị empty state
                    const visibleCount = document.querySelectorAll('#productsTable tbody tr:not([style*="display: none"])').length;
                    this.toggleEmptyState(visibleCount === 0);
                }
            }
        }

        updateTableInfo(visibleCount) {
            const currentCount = document.getElementById('currentCount');
            const totalCount = document.getElementById('totalCount');

            if (totalCount) totalCount.textContent = this.products.length;
            
            if (currentCount) {
                const startIndex = (this.currentPage - 1) * this.itemsPerPage + 1;
                const endIndex = Math.min(startIndex + visibleCount - 1, this.products.length);
                
                if (this.products.length === 0) {
                    currentCount.textContent = '0';
                } else {
                    currentCount.textContent = `${startIndex}-${endIndex}`;
                }
            }
        }

        toggleSelectAll(checked) {
            document.querySelectorAll('.row-checkbox').forEach(checkbox => {
                checkbox.checked = checked;
            });
        }

        // Product Modal Methods
        openProductModal(product = null) {
            console.log('🔵 openProductModal called with:', product ? 'edit mode' : 'create mode');
            try {
                this.currentEditId = product ? product.id : null;
                window.currentEditId = this.currentEditId; // Expose to window for upload functions

                // 🆕 Đảm bảo modal tồn tại trong DOM
                let modalElement = document.getElementById('productModal');
                if (!modalElement) {
                    console.error('❌ Product modal không tồn tại trong DOM');
                    this.showError('Lỗi: Modal không tồn tại. Vui lòng tải lại trang.');
                    return;
                }
                console.log('✅ Modal element found');

                // 🆕 Luôn tạo modal instance mới để đảm bảo fresh state
                const modal = new bootstrap.Modal(modalElement);
                
                // 🆕 Tìm các element với fallback
                let titlez = document.getElementById('modalTitle');
                let saveText = document.getElementById('saveButtonText');

                const title = modalElement.querySelector('.modal-title');
                const saveBtn = document.getElementById('saveProductBtn');

                // Nếu không tìm thấy element, thử tìm bằng cách khác
                if (!title) {
                    title = modalElement.querySelector('.modal-title');
                    if (title) title.id = 'modalTitle';
                }
                
                if (!saveText) {
                    const saveBtn = modalElement.querySelector('#saveProductBtn');
                    if (saveBtn) {
                        saveText = saveBtn.querySelector('span') || document.createElement('span');
                        saveText.id = 'saveButtonText';
                        if (!saveBtn.contains(saveText)) {
                            saveBtn.appendChild(saveText);
                        }
                    }
                }

                if (!title || !saveText) {
                    console.error('❌ Không thể tìm thấy element modal sau nhiều lần thử');
                    this.showError('Lỗi hiển thị form. Vui lòng tải lại trang.');
                    return;
                }

                if (product) {
                    title.textContent = 'Chỉnh sửa sản phẩm';
                    saveBtn.innerHTML = '<i class="fas fa-save"></i> Cập nhật sản phẩm';
                    // Lưu slug vào biến toàn cục để dùng cho upload
                    window.currentProductSlug = null; // Sẽ load từ MongoDB
                    this.fillProductForm(product);
                } else {
                    title.textContent = 'Thêm sản phẩm mới';
                    saveBtn.innerHTML = '<i class="fas fa-save"></i> Thêm sản phẩm';
                    window.currentProductSlug = null;
                    this.resetProductForm();
                }

                // 🆕 Xử lý sự kiện khi modal hoàn toàn hiển thị
                modalElement.addEventListener('shown.bs.modal', () => {
                    console.log('✅ Modal đã hiển thị hoàn toàn');
                }, { once: true });

                modal.show();
                
            } catch (error) {
                console.error('❌ Lỗi nghiêm trọng trong openProductModal:', error);
                this.showError('Lỗi hệ thống: ' + error.message);
            }
        }

        async fillProductForm(product) {

            this.resetProductForm();
            this.currentEditId = product.id;
            window.currentEditId = this.currentEditId; // Expose to window for upload functions

            console.log('Filling product form with data:', product);

            const productIdEl = document.getElementById('productId');
            const mongoDetailIdEl = document.getElementById('mongoDetailId');
            const productNameEl = document.getElementById('productName');
            const productSiteOriginEl = document.getElementById('productSiteOrigin');
            const productCategoryEl = document.getElementById('productCategory');
            const productBrandEl = document.getElementById('productBrand');
            const productStatusEl = document.getElementById('productStatus');
            const productDescriptionEl = document.getElementById('productDescription');
            const productFeaturedEl = document.getElementById('productFeatured');

            if (productIdEl) productIdEl.value = product.id || '';
            if (mongoDetailIdEl) mongoDetailIdEl.value = product.mongo_detail_id || '';
            if (productNameEl) productNameEl.value = product.ten_san_pham || '';
            
            // Site created (đã chuyển từ site_origin sang site_created trong product)
            if (productSiteOriginEl) {
                productSiteOriginEl.value = product.site_created || 'bac';
            }
            if (productCategoryEl) productCategoryEl.value = product.danh_muc_id || '';
            if (productBrandEl) productBrandEl.value = product.thuong_hieu_id || '';
            
            // Normalize trang_thai: convert về '0' hoặc '1'
            const normalizedStatus = (product.trang_thai === true || product.trang_thai === 1 || product.trang_thai === '1') ? '1' : '0';
            
            console.log('🔍 DEBUG fillProductForm - trang_thai:', {
                original: product.trang_thai,
                type: typeof product.trang_thai,
                normalized: normalizedStatus,
                productName: product.ten_san_pham
            });
            
            if (productStatusEl) {
                productStatusEl.value = normalizedStatus;
                console.log('✅ Set productStatus select to:', normalizedStatus, 'Element value now:', productStatusEl.value);
            }
            
            if (productDescriptionEl) productDescriptionEl.value = product.mo_ta || '';
            if (productFeaturedEl) productFeaturedEl.checked = product.san_pham_noi_bat || false;

            console.log ('Đã vào đc: ', product.mongo_detail_id);
            // Load thông tin từ MongoDB nếu có mongo_detail_id
            if (product.mongo_detail_id) {
                try {
                    console.log ('Đã vào đc');
                    const mongoResult = await ProductAPIService.getProductMongoDetail(product.id);
                    if (mongoResult.success && mongoResult.data) {
                        const mongoData = mongoResult.data;
                        console.log('📥 Loaded MongoDB data:', mongoData);
                        console.log('🔍 Debug - video_links:', mongoData.video_links);
                        console.log('🔍 Debug - variants:', mongoData.variants);
                        
                        // Load thông số kỹ thuật
                        if (window.productSpecsManager && mongoData.thong_so_ky_thuat) {
                            window.productSpecsManager.loadSpecsData(mongoData.thong_so_ky_thuat);
                        }

                        // 🟢 LOAD ẢNH HIỆN CÓ TỪ MONGODB (từ variants[region].hinh_anh)
                        // ⭐ Chỉ load ảnh của region đang active
                        if (mongoData.variants && typeof mongoData.variants === 'object') {
                            // Lấy region đang active từ ProductVariantsManager
                            const activeRegion = window.productVariantsManager?.activeRegion || 'bac';
                            const regionData = mongoData.variants[activeRegion];
                            
                            if (regionData?.hinh_anh && Array.isArray(regionData.hinh_anh) && regionData.hinh_anh.length > 0) {
                                // 🎲 Random ảnh chính từ danh sách ảnh
                                const randomIndex = Math.floor(Math.random() * regionData.hinh_anh.length);
                                const randomMainImage = regionData.hinh_anh[randomIndex];
                                
                                console.log(`🖼️ Loading existing images from region "${activeRegion}":`, {
                                    hinh_anh: regionData.hinh_anh,
                                    anh_dai_dien: randomMainImage
                                });
                                if (window.simpleImageUploadManager) {
                                    window.simpleImageUploadManager.loadExistingImages({
                                        hinh_anh: regionData.hinh_anh,
                                        anh_dai_dien: randomMainImage
                                    });
                                }
                            } else {
                                console.log(`📸 Region "${activeRegion}": No images to load`);
                            }
                        }

                        if (mongoData.videos && mongoData.videos.length > 0) {
                            console.log('🎬 Loading existing videos from MongoDB:', mongoData.videos);
                            if (window.simpleImageUploadManager) {
                                window.simpleImageUploadManager.loadExistingVideos({
                                    videos: mongoData.videos
                                });
                            }
                        }

                        // 🔗 LOAD VIDEO LINKS NẾU CÓ
                        if (mongoData.video_links && mongoData.video_links.length > 0) {
                            console.log('🔗 Loading existing video links from MongoDB:', mongoData.video_links);
                            if (window.videoLinksManager) {
                                window.videoLinksManager.loadVideoLinksData(mongoData.video_links);
                            }
                        }

                        // 📦 LOAD VARIANTS NẾU CÓ
                        // MongoDB variants có cấu trúc: { variants: { variant_options: [...], variant_combinations: [...] } }
                        
                        let variantsData = null;
                        
                        // Load variants từ MongoDB
                        if (mongoData.variants && typeof mongoData.variants === 'object') {
                            console.log('📦 Loading variants from MongoDB:', mongoData.variants);
                            variantsData = mongoData.variants; // variantsData = { variant_options: [...], variant_combinations: [...] }
                        }
                        
                        // ✅ KIỂM TRA NẾU KHÔNG CÓ BIẾN THỂ
                        const noVariantCheckbox = document.getElementById('noVariantCheckbox');
                        const simpleProductPricing = document.getElementById('simpleProductPricing');
                        const variantsManagement = document.getElementById('variantsManagement');
                        const addVariantTypeBtn = document.getElementById('addVariantTypeBtn');
                        
                        // Check if product has variants (NEW STRUCTURE: object with region keys)
                        let hasVariants = false;
                        if (variantsData && typeof variantsData === 'object') {
                            // Check NEW grouped structure: { bac: {...}, trung: {...} } OR { '1': {...}, '2': {...} }
                            const regions = Object.keys(variantsData);
                            const validRegionCodes = window.REGIONS_DATA ? window.REGIONS_DATA.map(r => r.code) : [];
                            
                            // Check if any key is a valid region code
                            const hasRegionKeys = regions.some(key => validRegionCodes.includes(key));
                            
                            if (hasRegionKeys) {
                                hasVariants = regions.some(region => {
                                    // Skip non-region keys like 'variant_combinations'
                                    if (!validRegionCodes.includes(region)) return false;
                                    
                                    const regionData = variantsData[region];
                                    return regionData?.variant_combinations && Array.isArray(regionData.variant_combinations) && regionData.variant_combinations.length > 0;
                                });
                            }
                            console.log('🔍 Checking variants structure:', { regions, validRegionCodes, hasRegionKeys, hasVariants });
                        }
                        
                        if (!hasVariants) {
                            console.log('✅ Sản phẩm không có biến thể - loading giá từ SQL variant');
                            
                            // Check checkbox "Không có biến thể"
                            if (noVariantCheckbox) {
                                noVariantCheckbox.checked = true;
                                
                                // Hiện form giá đơn giản
                                if (simpleProductPricing) simpleProductPricing.style.display = 'block';
                                if (variantsManagement) variantsManagement.style.display = 'none';
                                if (addVariantTypeBtn) addVariantTypeBtn.style.display = 'none';
                                
                                // Set required
                                document.getElementById('simpleListPrice').required = true;
                                document.getElementById('simpleSalePrice').required = true;
                                document.getElementById('simpleStock').required = true;
                            }
                            
                            // Load giá từ SQL product_variants (biến thể đầu tiên)
                            try {
                                const variantsResult = await ProductAPIService.getProductVariants(product.id);
                                if (variantsResult.success && variantsResult.data && variantsResult.data.length > 0) {
                                    const firstVariant = variantsResult.data[0];
                                    console.log('💰 Loading giá từ variant:', firstVariant);
                                    
                                    const simpleListPriceEl = document.getElementById('simpleListPrice');
                                    const simpleSalePriceEl = document.getElementById('simpleSalePrice');
                                    const simpleStockEl = document.getElementById('simpleStock');
                                    
                                    if (simpleListPriceEl) simpleListPriceEl.value = firstVariant.gia_niem_yet || 0;
                                    if (simpleSalePriceEl) simpleSalePriceEl.value = firstVariant.gia_ban || 0;
                                    if (simpleStockEl) simpleStockEl.value = firstVariant.so_luong_ton_kho || 0;
                                    
                                    console.log('✅ Đã load giá vào form đơn giản');
                                }
                            } catch (error) {
                                console.warn('⚠️ Không thể load giá từ variant:', error);
                            }
                        } else {
                            console.log('📦 Sản phẩm có biến thể - loading variants manager');
                            
                            // Uncheck checkbox
                            if (noVariantCheckbox) {
                                noVariantCheckbox.checked = false;
                                
                                // Hiện quản lý biến thể
                                if (simpleProductPricing) simpleProductPricing.style.display = 'none';
                                if (variantsManagement) variantsManagement.style.display = 'block';
                                if (addVariantTypeBtn) addVariantTypeBtn.style.display = 'inline-block';
                                
                                // Bỏ required
                                document.getElementById('simpleListPrice').required = false;
                                document.getElementById('simpleSalePrice').required = false;
                                document.getElementById('simpleStock').required = false;
                            }
                            
                            // Load variants vào manager
                            if (window.productVariantsManager) {
                                // 🔄 NEW LOGIC: Load từ SQL product_variants (source of truth)
                                // Chỉ hiển thị variants có trong SQL
                                await window.productVariantsManager.loadVariantsFromSQL(product.id, variantsData);
                                
                                console.log('✅ Variants loaded from SQL');
                                const allCombos = window.productVariantsManager.combinations || [];
                                console.log('📊 Final combinations:', allCombos.map(c => ({
                                    sku: c.sku,
                                    sql_variant_id: c.sql_variant_id,
                                    hasImage: !!c.image
                                })));
                            }
                        }
                        
                        // Thu thập ảnh từ variants và thêm vào productImages (không reload lại)
                        if (hasVariants && variantsData && window.simpleImageUploadManager) {
                            const currentImageUrls = window.simpleImageUploadManager.productImages.map(f => f.url);
                            
                            // Iterate through NEW grouped structure
                            Object.keys(variantsData).forEach(region => {
                                const regionData = variantsData[region];
                                if (regionData?.variant_combinations && Array.isArray(regionData.variant_combinations)) {
                                    regionData.variant_combinations.forEach(combo => {
                                        if (combo.image && !currentImageUrls.includes(combo.image)) {
                                            // Thêm vào productImages array (giữ nguyên mainImageIndex)
                                            const mockFile = {
                                                name: `variant_image_${combo.sku}.jpg`,
                                                type: 'image/jpeg',
                                                size: 0,
                                                url: combo.image,
                                                isExisting: true,
                                                isVariantImage: true
                                            };
                                            window.simpleImageUploadManager.productImages.push(mockFile);
                                            currentImageUrls.push(combo.image);
                                            console.log(`✅ Added variant image from ${region}:`, combo.image);
                                        }
                                    });
                                }
                            });
                            
                            // Re-render preview
                            if (currentImageUrls.length > 0) {
                                window.simpleImageUploadManager.renderProductImagesPreview();
                                console.log('✅ Re-rendered preview with variant images, mainImageIndex unchanged');
                            }
                        }

                        // 📋 LOAD THÔNG TIN KHÁC NẾU CÓ
                        if (mongoData.thong_tin_khac && Object.keys(mongoData.thong_tin_khac).length > 0) {
                            console.log('📋 Loading existing additional info from MongoDB:', mongoData.thong_tin_khac);
                            if (window.additionalInfoManager) {
                                window.additionalInfoManager.loadInfoData(mongoData.thong_tin_khac);
                            }
                        }

                        // 📄 LOAD MÔ TẢ, TRẠNG THÁI, NỔI BẬT
                        const productDescEl = document.getElementById('productDescription');
                        const productStatusEl = document.getElementById('productStatus');
                        const productFeaturedEl = document.getElementById('productFeatured');
                        
                        if (mongoData.mo_ta_chi_tiet && productDescEl) {
                            productDescEl.value = mongoData.mo_ta_chi_tiet;
                        }
                        
                        // ❌ KHÔNG load trang_thai từ MongoDB vì SQL là nguồn chính xác
                        // MongoDB có thể chứa dữ liệu cũ, đã set từ SQL ở trên rồi
                        console.log('⚠️ Skipping MongoDB trang_thai, using SQL value already set');
                        
                        if (mongoData.san_pham_noi_bat !== undefined && productFeaturedEl) {
                            productFeaturedEl.checked = mongoData.san_pham_noi_bat;
                        }
                    }
                } catch (error) {
                    console.warn('⚠️ Could not load MongoDB data:', error.message);
                    if (window.productSpecsManager) {
                        window.productSpecsManager.clearSpecs();
                    }
                    if (window.productVariantsManager) {
                        window.productVariantsManager.clearVariants();
                    }
                    if (window.additionalInfoManager) {
                        window.additionalInfoManager.clearInfo();
                    }
                    if (window.videoLinksManager) {
                        window.videoLinksManager.clearVideoLinks();
                    }
                    if (window.simpleImageUploadManager) {
                        window.simpleImageUploadManager.resetProductImages();
                        window.simpleImageUploadManager.resetProductVideos();
                    }
                }
            } else {
                if (window.productSpecsManager) {
                    window.productSpecsManager.clearSpecs();
                }
                if (window.productVariantsManager) {
                    window.productVariantsManager.clearVariants();
                }
                if (window.additionalInfoManager) {
                    window.additionalInfoManager.clearInfo();
                }
                if (window.videoLinksManager) {
                    window.videoLinksManager.clearVideoLinks();
                }

                // Reset ảnh và video nếu không có dữ liệu MongoDB
                if (window.simpleImageUploadManager) {
                    window.simpleImageUploadManager.resetProductImages();
                    window.simpleImageUploadManager.resetProductVideos();
                }
            }
        }



        resetProductForm() {
            console.log('🔄 Resetting product form - clearing all data');
            const wasEditing = this.currentEditId !== null;
            this.currentEditId = null;
            window.currentEditId = null; // Clear window reference
            
            // RESET ẢNH ĐẦU TIÊN VÀ LUÔN LUÔN
            if (window.simpleImageUploadManager) {
                console.log('🗑️ Force resetting product images');
                window.simpleImageUploadManager.productImages = [];
                // ⚠️ Không reset mainImageIndex nếu đang edit (sẽ được load lại từ anh_dai_dien)
                if (!wasEditing) {
                    window.simpleImageUploadManager.mainImageIndex = 0;
                }
                window.simpleImageUploadManager.productVideos = [];
                window.simpleImageUploadManager.renderProductImagesPreview();
                window.simpleImageUploadManager.renderProductVideosPreview();
            }
            
            // Sử dụng optional chaining cho an toàn
            const productFormEl = document.getElementById('productForm');
            const productStatusEl = document.getElementById('productStatus');
            
            if (productFormEl) productFormEl.reset();
            if (productStatusEl) productStatusEl.value = '1';
            
            if (window.productSpecsManager) {
                window.productSpecsManager.clearSpecs();
            }
            
            // ✅ Reset checkbox "Không có biến thể" và hiện lại
            const noVariantCheckbox = document.getElementById('noVariantCheckbox');
            const noVariantCheckboxWrapper = document.querySelector('.no-variant-checkbox-wrapper');
            const simpleProductPricing = document.getElementById('simpleProductPricing');
            const variantsManagement = document.getElementById('variantsManagement');
            const addVariantTypeBtn = document.getElementById('addVariantTypeBtn');
            
            if (noVariantCheckbox) noVariantCheckbox.checked = false;
            if (noVariantCheckboxWrapper) noVariantCheckboxWrapper.style.display = 'block'; // Hiện lại
            if (simpleProductPricing) simpleProductPricing.style.display = 'none';
            if (variantsManagement) variantsManagement.style.display = 'block';
            if (addVariantTypeBtn) addVariantTypeBtn.style.display = 'inline-block';
            
            console.log('✅ Product form reset complete');
        }

        // Sửa lại hàm saveProduct cho SCHEMA MỚI (products + product_variants)
        async saveProduct() {
            if (this.isSaving) {
                console.log('🛑 Đang trong quá trình lưu, bỏ qua');
                return;
            }

            this.isSaving = true;
            try {
                const saveBtn = document.getElementById('saveProductBtn');
                const originalText = saveBtn ? saveBtn.innerHTML : null;
                
                if (saveBtn) {
                    saveBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang xử lý...';
                    saveBtn.disabled = true;
                }

                // Kiểm tra xem có checkbox "Không có biến thể" không
                const noVariantCheckbox = document.getElementById('noVariantCheckbox');
                const isSimpleProduct = noVariantCheckbox?.checked || false;

                let variantsFormData, variantsManagerData;

                if (isSimpleProduct) {
                    // ========== SẢN PHẨM ĐỢN GIẢN (KHÔNG BIẾN THỂ) ==========
                    console.log('📦 Simple product mode - creating default variant');
                    
                    const listPrice = parseFloat(document.getElementById('simpleListPrice')?.value) || 0;
                    const salePrice = parseFloat(document.getElementById('simpleSalePrice')?.value) || 0;
                    const stock = parseInt(document.getElementById('simpleStock')?.value) || 0;
                    const productName = document.getElementById('productName')?.value?.trim() || '';
                    const siteOrigin = document.getElementById('productSiteOrigin')?.value || 'bac';
                    
                    // Validate
                    if (!listPrice || !salePrice) {
                        this.showError('Vui lòng nhập giá niêm yết và giá bán');
                        if (saveBtn) {
                            saveBtn.innerHTML = originalText;
                            saveBtn.disabled = false;
                        }
                        this.isSaving = false;
                        return;
                    }
                    
                    if (salePrice > listPrice) {
                        this.showError('Giá bán không được lớn hơn giá niêm yết');
                        if (saveBtn) {
                            saveBtn.innerHTML = originalText;
                            saveBtn.disabled = false;
                        }
                        this.isSaving = false;
                        return;
                    }
                    
                    // Tạo biến thể mặc định cho SQL
                    variantsFormData = [{
                        ma_sku: 'SKU' + Date.now(),
                        ten_hien_thi: productName,
                        gia_niem_yet: listPrice,
                        gia_ban: salePrice,
                        so_luong_ton_kho: stock,
                        site_origin: siteOrigin,
                        trang_thai: 1,
                        anh_dai_dien: null
                    }];
                    
                    // Tạo biến thể mặc định cho MongoDB (NEW GROUPED STRUCTURE)
                    // Structure: { site_origin: { variant_options: [], variant_combinations: [...] } }
                    variantsManagerData = {
                        [siteOrigin]: {  // Use site_origin as KEY
                            variant_options: [],
                            variant_combinations: [{
                                sku: variantsFormData[0].ma_sku,
                                name: productName,
                                price: salePrice,
                                original_price: listPrice,
                                stock: stock,
                                // NO site_origin field here - it's the parent key
                                active: true,
                                image: null
                            }]
                        }
                    };
                    
                    console.log('✅ Created default variant for simple product (grouped structure):', variantsManagerData);
                } else {
                    // ========== SẢN PHẨM CÓ BIẾN THỂ ==========
                    variantsFormData = this.getVariantsFormData();
                    variantsManagerData = window.productVariantsManager ? window.productVariantsManager.getVariantsData() : {};
                }

                // Lấy dữ liệu từ form
                const productData = this.getProductFormData();  // Dữ liệu bảng products
                const specsData = window.productSpecsManager ? window.productSpecsManager.getSpecsData() : {};
                const additionalInfoData = window.additionalInfoManager ? window.additionalInfoManager.getInfoData() : {};
                const videoLinksData = window.videoLinksManager ? window.videoLinksManager.getVideoLinksData() : [];

                console.log('📦 Product Data (bảng products):', productData);
                console.log('📦 Variants Data for SQL (product_variants table):', variantsFormData);
                console.log('📦 Variants Data for MongoDB (variant_options + combinations):', variantsManagerData);
                console.log('🔧 Technical Specs for MongoDB:', specsData);
                console.log('📋 Additional Info for MongoDB:', additionalInfoData);
                console.log('🔗 Video Links for MongoDB:', videoLinksData);

                // Validate
                if (!this.validateProductForm(productData)) {
                    if (saveBtn) {
                        saveBtn.innerHTML = originalText;
                        saveBtn.disabled = false;
                    }
                    this.isSaving = false;
                    return;
                }

                let productId, mongoDetailId;

                // ============================================
                // LUỒNG XỬ LÝ: SQL (products) → Upload Media → Variants → MongoDB
                // ============================================

                if (this.currentEditId) {
                    // ========== CẬP NHẬT SẢN PHẨM ==========
                    productId = this.currentEditId;
                    mongoDetailId = document.getElementById('mongoDetailId')?.value;
                    console.log('🔄 Updating Product ID:', productId, 'MongoDB ID:', mongoDetailId);
                    console.log('🔍 mongoDetailId type:', typeof mongoDetailId, 'empty?', !mongoDetailId);
                    
                    // Tính giá từ variants
                    const calculatedPrices = this.calculateProductPriceFromVariants(variantsFormData);
                    productData.gia_ban = calculatedPrices.gia_ban;
                    productData.gia_niem_yet = calculatedPrices.gia_niem_yet;
                    
                    // BƯỚC 1: Cập nhật thông tin sản phẩm trong SQL (chưa có ảnh)
                    console.log('📝 Step 1: Updating product in SQL...');
                    console.log('📦 SQL UPDATE data:', JSON.stringify(productData, null, 2));
                    const sqlUpdateResult = await ProductAPIService.updateProduct(productId, productData);
                    console.log('✅ Step 1 complete: Product updated in SQL', sqlUpdateResult);

                    // BƯỚC 1.5: Cập nhật variants trong product_variants bằng sql_variant_id
                    console.log('📝 Step 1.5: Updating variants in product_variants table...');
                    
                    // Duyệt qua từng combination và update vào SQL bằng sql_variant_id
                    // IMPORTANT: Use productVariantsManager.combinations directly to preserve imageFile
                    const directCombinations = window.productVariantsManager ? window.productVariantsManager.combinations : [];
                    console.log('🔍 Direct combinations with imageFile:', directCombinations.map(c => ({sku: c.sku, hasImageFile: !!c.imageFile, hasSqlId: !!c.sql_variant_id, sqlId: c.sql_variant_id, image: c.image?.substring(0, 50)})));
                    
                    // ✅ GIỮ LẠI: Không xóa variants cũ, chỉ update/tạo mới
                    console.log('✅ Keeping old variants in SQL - only update/create');
                    
                    if (directCombinations && directCombinations.length > 0) {
                        for (const combo of directCombinations) {
                            console.log(`🔎 Processing combo ${combo.sku}: sql_variant_id = ${combo.sql_variant_id}, hasImageFile = ${!!combo.imageFile}`);
                            if (combo.sql_variant_id) {
                                // Đã có sql_variant_id → UPDATE chỉ các field có giá trị
                                try {
                                    // Upload ảnh mới trước nếu có imageFile
                                    if (combo.imageFile) {
                                        try {
                                            console.log(`📤 Uploading new image for variant ${combo.sku}...`);
                                            const newImageUrl = await window.simpleImageUploadManager.uploadSingleImage(combo.imageFile);
                                            
                                            // Cập nhật combo hiện tại
                                            combo.image = newImageUrl;
                                            delete combo.imageFile;
                                            
                                            // Tìm và cập nhật combo trong variantsByRegion theo từng vùng
                                            if (window.productVariantsManager && window.productVariantsManager.variantsByRegion) {
                                                let foundAndUpdated = false;
                                                Object.keys(window.productVariantsManager.variantsByRegion).forEach(region => {
                                                    const regionData = window.productVariantsManager.variantsByRegion[region];
                                                    if (regionData && regionData.combinations) {
                                                        const targetCombo = regionData.combinations.find(
                                                            c => c.sql_variant_id === combo.sql_variant_id || c.sku === combo.sku
                                                        );
                                                        if (targetCombo) {
                                                            targetCombo.image = newImageUrl;
                                                            delete targetCombo.imageFile;
                                                            console.log(`✅ Synced image URL to variantsByRegion[${region}] for ${combo.sku}`);
                                                            foundAndUpdated = true;
                                                        }
                                                    }
                                                });
                                                if (!foundAndUpdated) {
                                                    console.warn(`⚠️ Could not find combo ${combo.sku} in any region to sync image`);
                                                }
                                            }
                                            
                                            console.log(`✅ Variant image uploaded: ${newImageUrl}`);
                                        } catch (uploadError) {
                                            console.error(`❌ Error uploading image for variant ${combo.sku}:`, uploadError);
                                        }
                                    }
                                    
                                    const updateData = {};
                                    
                                    // Update ten_hien_thi = name từ MongoDB (tên đầy đủ)
                                    // MongoDB lưu name = "Tên sản phẩm + Tên variant" (VD: "iPhone 15 Đen - 128GB")
                                    // Frontend chỉ hiển thị phần variant (combo.name = "Đen - 128GB")
                                    // Phải ghép lại để có tên đầy đủ khi update SQL
                                    if (combo.name !== undefined && combo.name !== null) {
                                        const productName = document.getElementById('productName')?.value?.trim() || '';
                                        updateData.ten_hien_thi = productName ? `${productName} ${combo.name}`.trim() : combo.name;
                                        console.log(`📝 Update ten_hien_thi to SQL: "${updateData.ten_hien_thi}"`);
                                    }
                                    
                                    // Chỉ update nếu có giá trị
                                    if (combo.sku !== undefined && combo.sku !== null) {
                                        updateData.ma_sku = combo.sku;
                                    }
                                    
                                    if (combo.price !== undefined && combo.price !== null) {
                                        updateData.gia_ban = parseFloat(combo.price);
                                    }
                                    
                                    if (combo.original_price !== undefined && combo.original_price !== null) {
                                        updateData.gia_niem_yet = parseFloat(combo.original_price);
                                    }
                                    
                                    if (combo.stock !== undefined && combo.stock !== null) {
                                        updateData.so_luong_ton_kho = parseInt(combo.stock);
                                    }
                                    
                                    if (combo.site_origin !== undefined && combo.site_origin !== null) {
                                        updateData.site_origin = combo.site_origin;
                                    }
                                    
                                    // Update ảnh nếu có (bao gồm cả ảnh mới upload)
                                    if (combo.image !== undefined && combo.image !== null) {
                                        updateData.anh_dai_dien = combo.image;
                                        console.log(`📸 Will update anh_dai_dien for variant ${combo.sku}: ${combo.image.substring(0, 60)}...`);
                                    }
                                    
                                    // Update trạng thái từ combo.active
                                    if (combo.active !== undefined && combo.active !== null) {
                                        updateData.trang_thai = combo.active ? 1 : 0;
                                    }
                                    
                                    // Chỉ gọi API nếu có field nào cần update
                                    if (Object.keys(updateData).length > 0) {
                                        await ProductAPIService.updateVariant(combo.sql_variant_id, updateData);
                                        console.log(`✅ Updated variant ${combo.sql_variant_id}:`, combo.sku);
                                    }
                                } catch (error) {
                                    console.error(`❌ Error updating variant ${combo.sql_variant_id}:`, error);
                                }
                            } else {
                                // Chưa có sql_variant_id → CREATE mới
                                try {
                                    // Upload ảnh trước nếu có imageFile
                                    let imageUrl = combo.image || null;
                                    if (combo.imageFile) {
                                        try {
                                            console.log(`📤 Uploading image for new variant ${combo.sku}...`);
                                            imageUrl = await window.simpleImageUploadManager.uploadSingleImage(combo.imageFile);
                                            
                                            // Cập nhật combo hiện tại
                                            combo.image = imageUrl;
                                            delete combo.imageFile;
                                            
                                            // Tìm và cập nhật combo trong variantsByRegion theo từng vùng
                                            if (window.productVariantsManager && window.productVariantsManager.variantsByRegion) {
                                                let foundAndUpdated = false;
                                                Object.keys(window.productVariantsManager.variantsByRegion).forEach(region => {
                                                    const regionData = window.productVariantsManager.variantsByRegion[region];
                                                    if (regionData && regionData.combinations) {
                                                        const targetCombo = regionData.combinations.find(
                                                            c => c.sku === combo.sku && c.site_origin === combo.site_origin
                                                        );
                                                        if (targetCombo) {
                                                            targetCombo.image = imageUrl;
                                                            delete targetCombo.imageFile;
                                                            console.log(`✅ Synced image URL to variantsByRegion[${region}] for ${combo.sku}`);
                                                            foundAndUpdated = true;
                                                        }
                                                    }
                                                });
                                                if (!foundAndUpdated) {
                                                    console.warn(`⚠️ Could not find combo ${combo.sku} in any region to sync image`);
                                                }
                                            }
                                            
                                            console.log(`✅ Variant image uploaded: ${imageUrl}`);
                                        } catch (uploadError) {
                                            console.error(`❌ Error uploading image for variant ${combo.sku}:`, uploadError);
                                        }
                                    }
                                    
                                    // Tạo tên hiển thị đầy đủ cho SQL
                                    const productName = document.getElementById('productName')?.value?.trim() || '';
                                    const fullVariantName = productName ? `${productName} ${combo.name || ''}`.trim() : (combo.name || 'N/A');
                                    
                                    const variantData = {
                                        ma_sku: combo.sku || `SKU-${Date.now()}`,
                                        ten_hien_thi: fullVariantName,
                                        gia_ban: parseFloat(combo.price) || 0,
                                        gia_niem_yet: parseFloat(combo.original_price) || parseFloat(combo.price) || 0,
                                        so_luong_ton_kho: parseInt(combo.stock) || 0,
                                        site_origin: combo.site_origin || 'bac',
                                        anh_dai_dien: imageUrl,
                                        trang_thai: combo.active !== undefined ? (combo.active ? 1 : 0) : 1
                                    };
                                    
                                    console.log(`📝 Creating variant with ten_hien_thi: "${fullVariantName}"`);
                                    
                                    console.log(`📸 Creating variant ${combo.sku} with anh_dai_dien: ${imageUrl ? imageUrl.substring(0, 60) + '...' : 'null'}`);
                                    const result = await ProductAPIService.createVariant(productId, variantData);
                                    const sqlVariantId = result.data.id;
                                    combo.sql_variant_id = sqlVariantId;
                                    console.log(`✅ Created new variant ${sqlVariantId} (${combo.sku}) with image in SQL`);
                                } catch (error) {
                                    console.error(`❌ Error creating variant ${combo.sku}:`, error);
                                }
                            }
                        }
                    }
                    console.log('✅ Step 1.5 complete: Variants updated in SQL');

                    // 🔄 CẬP NHẬT LẠI variantsManagerData SAU KHI UPLOAD ẢNH
                    // Vì ảnh đã được upload ở Step 1.5, combo.image đã có Cloudinary URL
                    // Cần gọi lại getVariantsData() để lấy dữ liệu mới nhất với link_anh
                    if (window.productVariantsManager) {
                        variantsManagerData = window.productVariantsManager.getVariantsData();
                        console.log('🔄 Refreshed variantsManagerData after image upload');
                    }

                    // BƯỚC 2: Chuẩn bị dữ liệu MongoDB - THU THẬP ẢNH VARIANTS ĐÃ UPLOAD
                    console.log('📝 Step 2: Preparing MongoDB data with variant images...');
                    
                    // Thu thập ảnh từ variants ĐÃ UPLOAD ở Step 1.5
                    const variantImages = [];
                    if (variantsManagerData && typeof variantsManagerData === 'object') {
                        Object.keys(variantsManagerData).forEach(region => {
                            const regionData = variantsManagerData[region];
                            if (regionData?.variant_combinations) {
                                regionData.variant_combinations.forEach(combo => {
                                    // Chỉ lấy Cloudinary URL, không lấy data URL
                                    if (combo.link_anh && !combo.link_anh.startsWith('data:')) {
                                        if (!variantImages.includes(combo.link_anh)) {
                                            variantImages.push(combo.link_anh);
                                            console.log(`✅ Collected variant image from ${region}: ${combo.link_anh.substring(0, 60)}...`);
                                        }
                                    }
                                });
                            }
                        });
                    }
                    console.log(`📸 Total variant images collected: ${variantImages.length}`);
                    
                    const mongoUpdateData = {
                        sql_product_id: productId,
                        thong_so_ky_thuat: specsData,
                        thong_tin_khac: additionalInfoData,
                        video_links: videoLinksData,
                        mo_ta_chi_tiet: document.getElementById('productDescription')?.value.trim() || '',
                        trang_thai: parseInt(document.getElementById('productStatus')?.value || 1),
                        san_pham_noi_bat: document.getElementById('productFeatured')?.checked || false,
                        slug: Utils.generateSlug(productData.ten_san_pham)
                        // ⚠️ KHÔNG có hinh_anh root level - ảnh nằm trong variants[region].hinh_anh
                    };
                    
                    // Thêm variants data - variantsManagerData ĐÃ grouped by site_origin từ getVariantsData()
                    if (variantsManagerData && Object.keys(variantsManagerData).length > 0) {
                        // variantsManagerData đã có cấu trúc: { bac: {...}, trung: {...}, nam: {...} }
                        // Chỉ cần clean imageFile và data URLs
                        const variantsByRegion = {};
                        
                        Object.keys(variantsManagerData).forEach(region => {
                            const regionData = variantsManagerData[region];
                            if (!regionData || !regionData.variant_combinations) return;
                            
                            const cleanedCombinations = regionData.variant_combinations.map((combo, index) => {
                                // DEBUG: Log combo trước khi xử lý
                                console.log(`🔍 UPDATE [${region}-${index}] Combo BEFORE clean:`, { 
                                    sku: combo.sku,
                                    hasImageFile: !!combo.imageFile,
                                    sql_variant_id: combo.sql_variant_id
                                });
                                
                                // Clean combo
                                const cleaned = { ...combo };
                                delete cleaned.imageFile;
                                if (cleaned.image && cleaned.image.startsWith('data:')) {
                                    cleaned.image = null;
                                }
                                
                                // Map sql_variant_id to variant_id for MongoDB
                                if (cleaned.sql_variant_id) {
                                    cleaned.variant_id = cleaned.sql_variant_id;
                                    console.log(`📝 UPDATE: Mapped variant_id for MongoDB [${region}]: ${combo.sku} → variant_id: ${cleaned.variant_id}`);
                                }
                                
                                // DEBUG: Verify cleaned combo
                                console.log(`🔍 UPDATE [${region}-${index}] Cleaned combo:`, { 
                                    sku: cleaned.sku,
                                    region: region,
                                    hasImageFile: false,
                                    variant_id: cleaned.variant_id
                                });
                                
                                return cleaned;
                            });
                            
                            variantsByRegion[region] = {
