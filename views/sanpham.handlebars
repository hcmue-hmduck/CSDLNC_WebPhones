    // Thêm vào class SimpleImageUploadManager
    async deleteImageFromCloudinary(imageUrl) {
        try {
            console.log('🗑️ Deleting image from Cloudinary:', imageUrl);
            
            const response = await fetch('/api/upload/image', {
                method: 'DELETE',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ imageUrl: imageUrl })
            });

            if (!response.ok) {
                const errorData = await response.json();
                throw new Error(errorData.message || 'Failed to delete image');
            }

            const result = await response.json();
            console.log('✅ Image deleted from Cloudinary:', result);
            return result;
            
        } catch (error) {
            console.error('❌ Error deleting image from Cloudinary:', error);
            throw error;
        }
    }

    // Hàm xoá ảnh khỏi MongoDB (từ variants[region].hinh_anh)
    async deleteImageFromMongoDB(productId, imageUrl) {
        try {
            console.log('🗑️ Removing image from MongoDB variants:', { productId, imageUrl });
            
            // Lấy document hiện tại
            const mongoDoc = await ProductAPIService.getProductMongoDetail(productId);
            if (!mongoDoc.success || !mongoDoc.data) {
                throw new Error('Không tìm thấy document MongoDB');
            }

            const currentData = mongoDoc.data;
            const variants = currentData.variants || {};

            // Xóa ảnh khỏi tất cả regions
            Object.keys(variants).forEach(region => {
                if (variants[region]?.hinh_anh) {
                    variants[region].hinh_anh = variants[region].hinh_anh.filter(img => img !== imageUrl);
                    console.log(`🗑️ Removed from region ${region}, remaining: ${variants[region].hinh_anh.length}`);
                }
            });

            // ⚠️ Kiểm tra nếu ảnh bị xóa là anh_dai_dien, chọn ảnh mới random
            let newAnhDaiDien = currentData.anh_dai_dien;
            
            if (currentData.anh_dai_dien === imageUrl) {
                console.log('⚠️ Deleted image was anh_dai_dien, selecting new random image...');
                
                // Thu thập tất cả ảnh còn lại từ các regions
                const remainingImages = [];
                Object.keys(variants).forEach(region => {
                    if (variants[region]?.hinh_anh?.length > 0) {
                        remainingImages.push(...variants[region].hinh_anh);
                    }
                });
                
                if (remainingImages.length > 0) {
                    // Random chọn ảnh mới
                    const randomIndex = Math.floor(Math.random() * remainingImages.length);
                    newAnhDaiDien = remainingImages[randomIndex];
                    console.log(`🎲 Selected new anh_dai_dien (${randomIndex + 1}/${remainingImages.length}):`, newAnhDaiDien?.substring(0, 60));
                } else {
                    // Không còn ảnh nào
                    newAnhDaiDien = null;
                    console.log('⚠️ No images remaining, anh_dai_dien set to null');
                }
            }

            // Cập nhật document MongoDB
            const updateData = {
                variants: variants,
                anh_dai_dien: newAnhDaiDien,
                updatedAt: new Date()
            };

            const updateResult = await ProductAPIService.updateProductMongoDetail(
                currentData._id, 
                updateData
            );

            console.log('✅ Image removed from MongoDB:', updateResult);
            return updateResult;
            
        } catch (error) {
            console.error('❌ Error removing image from MongoDB:', error);
            throw error;
        }
    }

