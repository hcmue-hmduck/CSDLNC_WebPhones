        // Cập nhật document MongoDB
        static async updateProductMongoDetail(mongoId, updateData) {
            try {
                console.log('🔧 API: Updating MongoDB document with ID:', mongoId);
                console.log('📤 Original update data (before cleaning):', JSON.stringify(updateData, null, 2));

                // Sử dụng deepCleanData để loại bỏ đệ quy tất cả field rỗng
                // isUpdate = true: GIỮ LẠI null để xóa field trong MongoDB
                const cleanedData = this.deepCleanData(updateData, true);
                
                console.log('✨ Cleaned update data (after deep clean - nulls preserved for deletion):', JSON.stringify(cleanedData, null, 2));
                
                // Log các field sẽ bị xóa (có giá trị null)
                const fieldsToDelete = Object.entries(cleanedData || {}).filter(([k, v]) => v === null).map(([k]) => k);
                if (fieldsToDelete.length > 0) {
                    console.log('🗑️ Fields that will be DELETED (set to null):', fieldsToDelete);
                }
                
                // Nếu không có dữ liệu gì để cập nhật sau khi clean, bỏ qua
                if (!cleanedData || Object.keys(cleanedData).length === 0) {
                    console.log('⚠️ No data to update after cleaning, skipping MongoDB update');
                    return { success: true, skipped: true, message: 'No data to update' };
                }

                const response = await fetch(`/api/mongo/sanpham/${mongoId}`, {
                    method: 'PUT',
                    headers: { 
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(cleanedData)
                });

                console.log('📨 Response status:', response.status);
                
                if (!response.ok) {
                    let errorMessage = `HTTP error! status: ${response.status}`;
                    try {
                        // Clone response để có thể đọc nhiều lần nếu cần
                        const clonedResponse = response.clone();
                        const errorData = await response.json();
                        errorMessage = errorData.message || errorMessage;
                        console.error('❌ Server error response:', errorData);
                    } catch (e) {
                        // Nếu không parse được JSON, thử text
                        try {
                            const errorText = await response.text();
                            errorMessage = errorText || errorMessage;
                            console.error('❌ Server error text:', errorText);
                        } catch (textError) {
                            console.error('❌ Could not parse error response:', textError);
                        }
                    }
                    throw new Error(errorMessage);
                }

                const result = await response.json();
                console.log('✅ MongoDB update successful:', result);
                return result;

            } catch (error) {
                console.error('❌ API Error updating MongoDB document:', error);
                throw new Error('Lỗi server khi cập nhật document MongoDB: ' + error.message);
            }
        }

