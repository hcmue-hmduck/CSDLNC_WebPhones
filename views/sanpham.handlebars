        // Hàm mới: Lấy dữ liệu variants để lưu vào product_variants table
        getVariantsFormData() {
            const variantsData = [];
            
            // Lấy tên sản phẩm
            const productName = document.getElementById('productName')?.value?.trim() || '';
            
            // Lấy dữ liệu từ variant manager nếu có
            if (window.productVariantsManager) {
                const variantsManagerData = window.productVariantsManager.getVariantsData();
                
                console.log('🔍 DEBUG getVariantsFormData - variantsManagerData:', JSON.stringify(variantsManagerData, null, 2));
                
                // NEW STRUCTURE: variantsManagerData có cấu trúc grouped by site_origin
                // { bac: { variant_options: [...], variant_combinations: [...] }, trung: {...}, nam: {...} }
                
                // Check if it's the NEW grouped structure (regions as keys)
                if (variantsManagerData && typeof variantsManagerData === 'object' && !Array.isArray(variantsManagerData)) {
                    const regions = Object.keys(variantsManagerData);
                    
                    // Check if keys look like regions using REGIONS_DATA dynamically
                    const validRegionCodes = window.REGIONS_DATA ? window.REGIONS_DATA.map(r => r.code) : [];
                    if (regions.length > 0 && regions.some(key => validRegionCodes.includes(key))) {
                        console.log('✅ Found NEW grouped structure, processing regions:', regions);
                        
                        // Iterate through each region
                        regions.forEach(region => {
                            const regionData = variantsManagerData[region];
                            console.log(`🗺️ Processing region ${region}:`, regionData);
                            
                            if (regionData?.variant_combinations && Array.isArray(regionData.variant_combinations)) {
                                console.log(`📦 Found ${regionData.variant_combinations.length} combinations in region ${region}`);
                                
                                regionData.variant_combinations.forEach((combo, index) => {
                                    console.log(`📦 [${region}][${index}] Processing combination:`, combo);
                                    
                                    // Ưu tiên ảnh đã upload (combo.image) > link_anh từ MongoDB > null
                                    const anhDaiDien = combo.image || combo.link_anh || null;
                                    
                                    // combo.name đã có tên sản phẩm từ getVariantsData()
                                    variantsData.push({
                                        ma_sku: combo.sku || 'SKU' + Date.now(),
                                        ten_hien_thi: combo.name,  // Đã có tên sản phẩm rồi
                                        gia_niem_yet: parseInt(combo.original_price || combo.price || 0),
                                        gia_ban: parseInt(combo.price) || 0,
                                        so_luong_ton_kho: parseInt(combo.stock) || 0,
                                        luot_ban: 0,  // Mặc định 0 khi tạo mới
                                        anh_dai_dien: anhDaiDien,
                                        site_origin: region,  // Use region key as site_origin
                                        trang_thai: combo.active !== undefined ? (combo.active ? 1 : 0) : 1,
                                        attributes: combo.attributes || {}
                                    });
                                });
                            }
                        });
                    } else {
                        console.warn('⚠️ Unknown structure format, keys:', regions);
                    }
                } else {
                    console.warn('⚠️ variantsManagerData is not an object or is an array');
                }
            } else {
                console.warn('⚠️ window.productVariantsManager not found');
            }

            console.log('📦 Variants Form Data for product_variants table (final):', variantsData);
            console.log(`📊 Total variants to insert: ${variantsData.length}`);
            return variantsData;
        }

        // Tính giá bán và giá niêm yết cho product từ variant có giá bán thấp nhất
        calculateProductPriceFromVariants(variantsData) {
            if (!variantsData || variantsData.length === 0) {
                return { gia_ban: 0, gia_niem_yet: 0 };
            }

            // Tìm variant có giá bán thấp nhất
            const minPriceVariant = variantsData.reduce((min, variant) => {
                const variantPrice = parseInt(variant.gia_ban) || 0;
                const minPrice = parseInt(min.gia_ban) || 0;
                return variantPrice < minPrice ? variant : min;
            });

            const gia_ban = parseInt(minPriceVariant.gia_ban) || 0;
            const gia_niem_yet = parseInt(minPriceVariant.gia_niem_yet) || gia_ban;

            console.log('💰 Calculated prices from variants:', {
                gia_ban,
                gia_niem_yet,
                from_variant: minPriceVariant.ma_sku
            });

            return { gia_ban, gia_niem_yet };
        }
        
        
        // Cập nhật hàm validateProductForm cho schema mới
        validateProductForm(formData) {
            const errors = [];

            if (!formData.ten_san_pham) {
                errors.push('Vui lòng nhập tên sản phẩm');
            }
            if (!formData.danh_muc_id) {
                errors.push('Vui lòng chọn danh mục');
            }
            if (!formData.thuong_hieu_id) {
                errors.push('Vui lòng chọn thương hiệu');
            }

            // Kiểm tra checkbox "Không có biến thể"
            const noVariantCheckbox = document.getElementById('noVariantCheckbox');
            const isSimpleProduct = noVariantCheckbox?.checked || false;

            if (isSimpleProduct) {
                // Validate form giá đơn giản
                const listPrice = parseFloat(document.getElementById('simpleListPrice')?.value) || 0;
                const salePrice = parseFloat(document.getElementById('simpleSalePrice')?.value) || 0;
                
                if (!listPrice || listPrice <= 0) {
                    errors.push('Vui lòng nhập giá niêm yết hợp lệ');
                }
                if (!salePrice || salePrice <= 0) {
                    errors.push('Vui lòng nhập giá bán hợp lệ');
                }
                if (salePrice > listPrice) {
                    errors.push('Giá bán không được lớn hơn giá niêm yết');
                }
            } else {
                // Validate biến thể
                const variantsData = this.getVariantsFormData();
                if (variantsData.length === 0) {
                    errors.push('Vui lòng thêm ít nhất 1 biến thể sản phẩm hoặc chọn "Không có biến thể"');
                } else {
                    // Validate từng variant
                    variantsData.forEach((variant, index) => {
                        if (!variant.gia_ban || variant.gia_ban <= 0) {
                            errors.push(`Biến thể ${index + 1}: Giá bán không hợp lệ`);
                        }
                        if (!variant.ma_sku) {
                            errors.push(`Biến thể ${index + 1}: Thiếu mã SKU`);
                        }
                    });
                }
            }

            if (errors.length > 0) {
                this.showError(errors.join('<br>'));
                return false;
            }

            return true;
        }

