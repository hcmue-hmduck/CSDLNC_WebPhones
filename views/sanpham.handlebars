<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>

<script>
    // Global regions data from server
    window.REGIONS_DATA = [
        {{#each regions}}
        {
            ma_vung: '{{this.ma_vung}}',
            ten_vung: '{{this.ten_vung}}',
            code: '{{this.ma_vung}}',
            name: '{{this.ten_vung}}'
        }{{#unless @last}},{{/unless}}
        {{/each}}
    ];
    
    console.log('✅ REGIONS_DATA loaded:', window.REGIONS_DATA);
    
    // Utility Functions
    const Utils = {
        formatCurrency(amount) {
            return new Intl.NumberFormat('vi-VN', {
                style: 'currency',
                currency: 'VND'
            }).format(amount || 0);
        },

        formatCompactCurrency(amount) {
            if (!amount || amount === 0) return '0₫';
            
            const billion = 1000000000;
            const million = 1000000;
            const thousand = 1000;
            
            if (amount >= billion) {
                return (amount / billion).toFixed(1) + ' tỷ';
            } else if (amount >= million) {
                return (amount / million).toFixed(1) + ' tr';
            } else if (amount >= thousand) {
                return (amount / thousand).toFixed(0) + ' K';
            } else {
                return amount.toLocaleString('vi-VN') + '₫';
            }
        },

        debounce(func, wait) {
            let timeout;
            return function executedFunction(...args) {
                const later = () => {
                    clearTimeout(timeout);
                    func(...args);
                };
                clearTimeout(timeout);
                timeout = setTimeout(later, wait);
            };
        },

        generateSlug(text) {
            return text
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/[đĐ]/g, 'd')
                .replace(/[^a-z0-9 -]/g, '')
                .replace(/\s+/g, '-')
                .replace(/-+/g, '-');
        },

        validateImageUrl(url) {
            return new Promise((resolve) => {
                if (!url) {
                    resolve(false);
                    return;
                }
                const img = new Image();
                img.onload = () => resolve(true);
               
                img.src = url;
            });
        },

        escapeHtml(unsafe) {
            if (!unsafe) return '';
            return unsafe
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }
    };

    // API Service
    class ProductAPIService {
        // ============================================
        // UTILITY: Deep Clean MongoDB Document
        // ============================================
        /**
         * Loại bỏ tất cả các field không có dữ liệu (null, undefined, empty string, empty array, empty object)
         * Xử lý đệ quy cho nested objects và arrays
         * @param {*} data - Dữ liệu cần clean
         * @param {boolean} isUpdate - Nếu true, giữ lại null để xóa field trong UPDATE
         * @returns {*} - Dữ liệu đã được clean
         */
        static deepCleanData(data, isUpdate = false) {
            // Nếu là null
            if (data === null) {
                // Trong UPDATE: giữ lại null để backend biết cần xóa field
                // Trong CREATE: loại bỏ null
                return isUpdate ? null : undefined;
            }
            
            // Nếu là undefined, luôn loại bỏ
            if (data === undefined) {
                return undefined;
            }

            // Nếu là string
            if (typeof data === 'string') {
                const trimmed = data.trim();
                if (trimmed === '') {
                    // Trong UPDATE: trả về null để backend xóa field
                    // Trong CREATE: trả về undefined để bỏ qua field
                    return isUpdate ? null : undefined;
                }
                return data;
            }

            // Nếu là number hoặc boolean, giữ nguyên (kể cả 0 hay false)
            if (typeof data === 'number' || typeof data === 'boolean') {
                return data;
            }

            // Nếu là array
            if (Array.isArray(data)) {
                // Clean từng phần tử trong array
                const cleanedArray = data
                    .map(item => this.deepCleanData(item, isUpdate))
                    .filter(item => item !== undefined);
                
                // Nếu array rỗng sau khi clean
                if (cleanedArray.length === 0) {
                    // Trong UPDATE: trả về null để backend xóa field
                    // Trong CREATE: trả về undefined để bỏ qua field
                    return isUpdate ? null : undefined;
                }
                
                return cleanedArray;
            }

            // Nếu là object
            if (typeof data === 'object') {
                const cleanedObject = {};
                
                for (const [key, value] of Object.entries(data)) {
                    const cleanedValue = this.deepCleanData(value, isUpdate);
                    
                    // Giữ lại field nếu:
                    // - Có dữ liệu (cleanedValue !== undefined)
                    // - Hoặc là null trong UPDATE mode (để xóa field)
                    if (cleanedValue !== undefined || (isUpdate && cleanedValue === null)) {
                        cleanedObject[key] = cleanedValue;
                    }
                }
                
                // Nếu object rỗng sau khi clean
                if (Object.keys(cleanedObject).length === 0) {
                    // Trong UPDATE: trả về null để backend xóa field
                    // Trong CREATE: trả về undefined để bỏ qua field
                    return isUpdate ? null : undefined;
                }
                
                return cleanedObject;
            }

            // Các kiểu dữ liệu khác (Date, RegExp, ...) giữ nguyên
            return data;
        }

