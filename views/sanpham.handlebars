                };

                // Sử dụng deepCleanData để loại bỏ đệ quy tất cả field rỗng
                // isUpdate = false: loại bỏ null trong CREATE
                const cleanedData = this.deepCleanData(rawData, false);

                // Đảm bảo sql_product_id luôn có (required field)
                const requestBody = {
                    sql_product_id: sql_product_id,
