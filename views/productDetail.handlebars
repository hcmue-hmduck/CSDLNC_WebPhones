  // Setup listeners for variant buttons (click to select variant directly)
  function setupVariantOptionListeners(siteOrigin) {
    const optionButtons = document.querySelectorAll('.cps-variant-option');
    
    optionButtons.forEach(btn => {
      // Remove old listeners by cloning the button (removes all event listeners)
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
      
      // Add new listener
      newBtn.addEventListener('click', function() {
        const variantIndex = parseInt(this.getAttribute('data-variant-index'));
        const sku = this.getAttribute('data-sku');
        
        // Remove active from all siblings
        document.querySelectorAll('.cps-variant-option').forEach(b => b.classList.remove('active'));
        
        // Add active to this button
        this.classList.add('active');
        
        console.log('✅ Selected variant index:', variantIndex, 'SKU:', sku);
        
        // Display the selected variant directly
        displaySelectedVariant(siteOrigin, variantIndex);
      });
    });
  }
  
