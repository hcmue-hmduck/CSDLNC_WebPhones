<!-- SweetAlert2 -->
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
// Require login for this page
if (!AuthHelper.requireLogin()) {
    // Will redirect to login if not authenticated
}

// Load user profile from database using session info
async function loadUserProfile() {
    // Get user session (only id and email)
    const userSession = AuthHelper.getCurrentUser();
    
    if (!userSession || !userSession.id) {
        console.error('❌ No user session found');
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Phiên đăng nhập hết hạn. Vui lòng đăng nhập lại.'
        }).then(() => {
            window.location.href = '/login';
        });
        return;
    }
    
    console.log('🔄 Loading profile from database using email:', userSession.email);
    
    try {
        // Query database by EMAIL to get full user info
        const encodedEmail = encodeURIComponent(userSession.email);
        const response = await fetch('/api/profile/by-email/' + encodedEmail, {
            method: 'GET',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + AuthHelper.getAuthToken()
            }
        });
        
        const result = await response.json();
        
        if (result.success && result.data) {
            const userData = result.data.user;
            const extendedData = result.data.extendedProfile;
            
            console.log('✅ Profile data loaded from DB:', userData);
            
            // Update sidebar
            const initials = (userData.ho_ten || userData.email).substring(0, 2).toUpperCase();
            document.getElementById('avatarInitials').textContent = initials;
            document.getElementById('profileName').textContent = userData.ho_ten || 'Chưa cập nhật';
            document.getElementById('profileEmail').textContent = userData.email;
            
            // Update form - SQL data
            document.getElementById('inputHoTen').value = userData.ho_ten || '';
            document.getElementById('inputEmail').value = userData.email || '';
            document.getElementById('inputPhone').value = userData.so_dien_thoai || '';
            document.getElementById('inputVung').value = userData.vung_id || 'bac';
            
            // Update form - Extended MongoDB data
            if (extendedData) {
                document.getElementById('inputDiaChi').value = extendedData.dia_chi || '';
            } else {
                document.getElementById('inputDiaChi').value = '';
            }
            
            // Format registration date
            if (userData.ngay_dang_ky) {
                const date = new Date(userData.ngay_dang_ky);
                document.getElementById('inputNgayDangKy').textContent = date.toLocaleDateString('vi-VN', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit'
                });
            }
            
        } else {
            throw new Error(result.message || 'Không thể tải thông tin profile');
        }
        
    } catch (error) {
        console.error('❌ Load profile error:', error);
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Không thể tải thông tin profile: ' + error.message
        });
    }
}

// Update profile
document.getElementById('profileForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const userSession = AuthHelper.getCurrentUser();
    
    if (!userSession || !userSession.id) {
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Không tìm thấy thông tin người dùng'
        });
        return;
    }
    
    const updateData = {
        ho_ten: document.getElementById('inputHoTen').value.trim(),
        so_dien_thoai: document.getElementById('inputPhone').value.trim(),
        vung_id: document.getElementById('inputVung').value,
        dia_chi: document.getElementById('inputDiaChi').value.trim()
    };
    
    // Validate
    if (!updateData.ho_ten) {
        Swal.fire({
            icon: 'warning',
            title: 'Cảnh báo',
            text: 'Vui lòng nhập họ tên'
        });
        return;
    }
    
    console.log('📤 Updating profile:', updateData);
    
    try {
        const response = await fetch('/api/profile/' + userSession.id, {
            method: 'PUT',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + AuthHelper.getAuthToken()
            },
            body: JSON.stringify(updateData)
        });
        
        const result = await response.json();
        
        if (result.success) {
            console.log('✅ Profile updated:', result.data);
            
            Swal.fire({
                icon: 'success',
                title: 'Cập nhật thành công',
                text: 'Thông tin của bạn đã được cập nhật',
                timer: 2000,
                showConfirmButton: false
            });
            
            // Reload profile sau khi update
            setTimeout(() => loadUserProfile(), 500);
        } else {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: result.message || 'Không thể cập nhật thông tin'
            });
        }
    } catch (error) {
        console.error('❌ Update error:', error);
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Không thể kết nối đến server'
        });
    }
});

// Change password
document.getElementById('changePasswordForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const userSession = AuthHelper.getCurrentUser();
    
    if (!userSession || !userSession.id) {
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Không tìm thấy thông tin người dùng'
        });
        return;
    }
    
    const currentPassword = document.getElementById('currentPassword').value;
    const newPassword = document.getElementById('newPassword').value;
    const confirmPassword = document.getElementById('confirmPassword').value;
    
    if (!currentPassword || !newPassword || !confirmPassword) {
        Swal.fire({
            icon: 'warning',
            title: 'Cảnh báo',
            text: 'Vui lòng nhập đầy đủ thông tin'
        });
        return;
    }
    
    if (newPassword !== confirmPassword) {
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Mật khẩu xác nhận không khớp'
        });
        return;
    }
    
    if (newPassword.length < 6) {
        Swal.fire({
            icon: 'warning',
            title: 'Cảnh báo',
            text: 'Mật khẩu mới phải có ít nhất 6 ký tự'
        });
        return;
    }
    
    console.log('🔐 Changing password for user:', userSession.id);
    
    try {
        const response = await fetch('/api/profile/' + userSession.id + '/change-password', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': 'Bearer ' + AuthHelper.getAuthToken()
            },
            body: JSON.stringify({
                current_password: currentPassword,
                new_password: newPassword
            })
        });
        
        const result = await response.json();
        
        if (result.success) {
            console.log('✅ Password changed successfully');
            
            // Clear form
            document.getElementById('changePasswordForm').reset();
            
            Swal.fire({
                icon: 'success',
                title: 'Thành công',
                text: 'Đổi mật khẩu thành công. Vui lòng đăng nhập lại.',
                confirmButtonText: 'Đăng nhập lại'
            }).then(() => {
                // Logout và redirect về login
                AuthHelper.logout();
            });
        } else {
            Swal.fire({
                icon: 'error',
                title: 'Lỗi',
                text: result.message || 'Không thể đổi mật khẩu'
            });
        }
    } catch (error) {
        console.error('❌ Change password error:', error);
        Swal.fire({
            icon: 'error',
            title: 'Lỗi',
            text: 'Không thể kết nối đến server'
        });
    }
});

// Logout button
document.getElementById('btnProfileLogout').addEventListener('click', function(e) {
    e.preventDefault();
    
    Swal.fire({
        title: 'Đăng xuất',
        text: 'Bạn có chắc muốn đăng xuất?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonText: 'Đăng xuất',
        cancelButtonText: 'Hủy',
        confirmButtonColor: '#dc3545'
    }).then((result) => {
        if (result.isConfirmed) {
            AuthHelper.logout();
        }
    });
});

// Initialize - Load profile when page loads
loadUserProfile();
</script>

