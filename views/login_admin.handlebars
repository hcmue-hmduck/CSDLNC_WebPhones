<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">


<div class="login-wrapper">
        <div class="login-container">
            <!-- Header -->
            <div class="login-header">
                <div class="logo-container">
                    <img src="/icon/logo.png" alt="WebPhones Logo" onerror="this.style.display='none'">
                </div>
                <h2>HỆ THỐNG QUẢN TRỊ</h2>
                <p>WebPhones Management System</p>
            </div>

            <!-- Body -->
            <div class="login-body">
                <div class="welcome-text">
                    <h3>Chào mừng trở lại!</h3>
                    <p>Đăng nhập để tiếp tục quản lý hệ thống</p>
                </div>

                <div id="alertContainer"></div>

                <form id="loginForm">
                    <input type="hidden" name="redirect" value="{{{redirect}}}">

                    <div class="form-group">
                        <label for="email" class="form-label">
                            <i class="fas fa-envelope"></i>
                            Email
                        </label>
                        <div class="input-wrapper">
                            <i class="fas fa-user input-icon"></i>
                            <input 
                                type="email" 
                                class="form-control" 
                                id="email"
                                name="email"
                                placeholder="Nhập email của bạn"
                                required
                                autocomplete="email"
                            >
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="password" class="form-label">
                            <i class="fas fa-lock"></i>
                            Mật khẩu
                        </label>
                        <div class="input-wrapper">
                            <i class="fas fa-key input-icon"></i>
                            <input 
                                type="password" 
                                class="form-control" 
                                id="password"
                                name="password"
                                placeholder="Nhập mật khẩu"
                                required
                                autocomplete="current-password"
                            >
                        </div>
                    </div>

                    <button type="submit" class="btn btn-login" id="loginBtn">
                        <span id="btnText">
                            <i class="fas fa-sign-in-alt me-2"></i>
                            Đăng nhập
                        </span>
                    </button>
                </form>
            </div>

            <!-- Footer -->
            <div class="login-footer">
                <p>© 2024 WebPhones. All rights reserved.</p>
            </div>
        </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const alertContainer = document.getElementById('alertContainer');
            const loginBtn = document.getElementById('loginBtn');
            const btnText = document.getElementById('btnText');
            
            // Get form data
            const formData = {
                email: document.getElementById('email').value,
                password: document.getElementById('password').value,
                redirect: document.querySelector('input[name="redirect"]').value
            };

            // Disable button
            loginBtn.disabled = true;
            btnText.innerHTML = '<span class="spinner me-2"></span>Đang xử lý...';
            alertContainer.innerHTML = '';

            try {
                const response = await fetch('/admin-login', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(formData)
                });

                const data = await response.json();

                if (data.success) {
                    alertContainer.innerHTML = `
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i>
                            <span>${data.message}</span>
                        </div>
                    `;
                    
                    btnText.innerHTML = '<i class="fas fa-check me-2"></i>Thành công!';
                    
                    // Redirect after 800ms
                    setTimeout(() => {
                        window.location.href = data.redirect || '/admin';
                    }, 800);
                } else {
                    alertContainer.innerHTML = `
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i>
                            <span>${data.message}</span>
                        </div>
                    `;
                    loginBtn.disabled = false;
                    btnText.innerHTML = '<i class="fas fa-sign-in-alt me-2"></i>Đăng nhập';
                    
                    // Scroll to alert
                    alertContainer.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                }
            } catch (error) {
                console.error('Login error:', error);
                alertContainer.innerHTML = `
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span>Lỗi kết nối server. Vui lòng thử lại sau.</span>
                    </div>
                `;
                loginBtn.disabled = false;
                btnText.innerHTML = '<i class="fas fa-sign-in-alt me-2"></i>Đăng nhập';
            }
        });

        // Enter key on inputs
        document.getElementById('email').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                document.getElementById('password').focus();
            }
        });
</script>


<style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cps-red: #d70018;
            --cps-red-dark: #b8000f;
            --cps-red-light: #ff0033;
            --cps-dark: #1a1a1a;
            --cps-gray: #666666;
            --cps-light-gray: #f4f4f4;
            --cps-border: #e0e0e0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background: #f5f5f5;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        body::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle, rgba(215, 0, 24, 0.05) 0%, transparent 70%);
            animation: pulse 15s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }

        .login-wrapper {
            position: relative;
            z-index: 1;
            width: 100%;
            max-width: 480px;
        }

        .login-container {
            background: white;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            overflow: hidden;
            border: 1px solid var(--cps-border);
        }

        .login-header {
            background: linear-gradient(135deg, var(--cps-red) 0%, var(--cps-red-dark) 100%);
            padding: 45px 35px;
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .login-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .logo-container {
            position: relative;
            z-index: 2;
            margin-bottom: 20px;
        }

        .logo-container img {
            max-width: 180px;
            height: auto;
            filter: brightness(0) invert(1);
            opacity: 0.95;
        }

        .login-header h2 {
            position: relative;
            z-index: 2;
            margin: 0;
            font-size: 1.75rem;
            font-weight: 700;
            color: white;
            letter-spacing: -0.5px;
        }

        .login-header p {
            position: relative;
            z-index: 2;
            margin: 8px 0 0 0;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.95rem;
            font-weight: 400;
        }

        .login-body {
            padding: 40px 35px;
            background: white;
        }

        .welcome-text {
            text-align: center;
            margin-bottom: 30px;
        }

        .welcome-text h3 {
            font-size: 1.3rem;
            font-weight: 700;
            color: var(--cps-dark);
            margin-bottom: 8px;
        }

        .welcome-text p {
            color: var(--cps-gray);
            font-size: 0.9rem;
            margin: 0;
        }

        .form-group {
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 600;
            color: var(--cps-dark);
            margin-bottom: 10px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-label i {
            color: var(--cps-red);
            font-size: 0.95rem;
        }

        .input-wrapper {
            position: relative;
        }

        .form-control {
            border: 2px solid var(--cps-border);
            border-radius: 10px;
            padding: 14px 16px 14px 48px;
            font-size: 0.95rem;
            transition: all 0.3s;
            background: #fafafa;
        }

        .form-control:focus {
            border-color: var(--cps-red);
            background: white;
            box-shadow: 0 0 0 4px rgba(215, 0, 24, 0.08);
            outline: none;
        }

        .form-control::placeholder {
            color: #bbb;
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--cps-gray);
            font-size: 1.1rem;
            transition: all 0.3s;
            pointer-events: none;
        }

        .input-wrapper:focus-within .input-icon {
            color: var(--cps-red);
        }

        .btn-login {
            background: linear-gradient(135deg, var(--cps-red) 0%, var(--cps-red-dark) 100%);
            border: none;
            border-radius: 10px;
            padding: 15px;
            font-size: 1rem;
            font-weight: 700;
            width: 100%;
            color: white;
            transition: all 0.3s;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            box-shadow: 0 4px 15px rgba(215, 0, 24, 0.3);
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(215, 0, 24, 0.4);
            background: linear-gradient(135deg, var(--cps-red-light) 0%, var(--cps-red) 100%);
        }

        .btn-login:active {
            transform: translateY(0);
        }

        .btn-login:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .alert {
            border-radius: 10px;
            border: none;
            padding: 14px 18px;
            margin-bottom: 24px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 10px;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .alert-success {
            background: #d4edda;
            color: #155724;
            border-left: 4px solid #28a745;
        }

        .alert-danger {
            background: #f8d7da;
            color: #721c24;
            border-left: 4px solid #dc3545;
        }

        .alert i {
            font-size: 1.2rem;
        }

        .login-footer {
            text-align: center;
            padding: 20px 35px 30px;
            background: #fafafa;
            border-top: 1px solid var(--cps-border);
        }

        .login-footer p {
            margin: 0;
            color: var(--cps-gray);
            font-size: 0.85rem;
        }

        .login-footer a {
            color: var(--cps-red);
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
        }

        .login-footer a:hover {
            color: var(--cps-red-dark);
            text-decoration: underline;
        }

        /* Loading spinner */
        .spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.6s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Responsive */
        @media (max-width: 576px) {
            .login-header {
                padding: 35px 25px;
            }

            .login-body {
                padding: 30px 25px;
            }

            .login-header h2 {
                font-size: 1.5rem;
            }

            .logo-container img {
                max-width: 150px;
            }
        }
</style>