// Render warehouse tables
function renderWarehouseTables() {
    warehousesData.forEach(wh => {
        renderWarehouseTable(wh.id);
    });
}

function renderWarehouseTable(warehouseId, searchTerm = '', filterLevel = '') {
    const tbody = document.getElementById('whTable' + warehouseId);
    if (!tbody) return;
    
    // Initialize pagination for this warehouse if not exists
    if (!warehousePagination[warehouseId]) {
        warehousePagination[warehouseId] = { currentPage: 1, itemsPerPage: 10 };
    }
    
    // Get warehouse info
    const warehouse = warehousesData.find(w => w.id == warehouseId);
    if (!warehouse) {
        tbody.innerHTML = '<tr><td colspan="8" class="text-center">Không tìm thấy kho</td></tr>';
        return;
    }
    
    // DEBUG: Log all data
    console.log('🔍 DEBUG renderWarehouseTable:');
    console.log('  warehouseId:', warehouseId);
    console.log('  warehouse:', warehouse);
    console.log('  productsData:', productsData);
    console.log('  productsData.length:', productsData.length);
    console.log('  variantsData.length:', variantsData.length);
    console.log('  inventoryData.length:', inventoryData.length);
    
    // Check if productsData is actually an array
    if (!Array.isArray(productsData)) {
        console.error('❌ productsData is NOT an array!', typeof productsData);
        tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger">Lỗi: productsData không phải là array</td></tr>';
        return;
    }
    
    // Filter products by search term
    let filteredProducts = productsData;
    if (searchTerm) {
        filteredProducts = productsData.filter(p =>
            (p.ten_san_pham || '').toLowerCase().includes(searchTerm.toLowerCase()) ||
            (p.ma_san_pham || '').toLowerCase().includes(searchTerm.toLowerCase())
        );
    }
    console.log('  🔎 Filtered products:', filteredProducts.length);
    
    // Build product groups with variants and inventory
    const productGroups = [];
    console.log('  📦 Building product groups from', filteredProducts.length, 'products');
    
    filteredProducts.forEach((product, idx) => {
        console.log(`  📦 [${idx+1}] Processing product:`, {
            id: product.id,
            ten_san_pham: product.ten_san_pham,
            ma_san_pham: product.ma_san_pham
        });
        
        // Find variants for this product AND warehouse region
        const productVariants = variantsData.filter(v =>
            v.san_pham_id === product.id && v.site_origin === warehouse.vung_id
        );
        
        console.log(`    → Found ${productVariants.length} variants matching:`, {
            san_pham_id: product.id,
            site_origin: warehouse.vung_id,
            variant_ids: productVariants.map(v => v.id)
        });
        
        if (productVariants.length === 0) {
            console.log(`    ⚠️ Skipping product (no matching variants)`);
            return;
        }
        
        // Get inventory for each variant
        const variantInventories = productVariants.map(variant => {
            const inv = inventoryData.find(i =>
                i.variant_id === variant.id && i.kho_id == warehouseId
            );
            return {
                variant,
                inventory: inv || null
            };
        }).filter(vi => vi.inventory !== null);
        
        console.log(`      -> ${variantInventories.length} variants with inventory in this warehouse`);
        
        if (variantInventories.length === 0) return;
        
        // Apply filter on variants
        let filteredVariantInventories = variantInventories;
        if (filterLevel) {
            filteredVariantInventories = variantInventories.filter(vi => {
                const avail = vi.inventory.so_luong_kha_dung || 0;
                const min = vi.inventory.muc_ton_kho_toi_thieu || 0;
                if (filterLevel === 'low') return avail < min;
                if (filterLevel === 'normal') return avail >= min && avail < min * 2;
                if (filterLevel === 'high') return avail >= min * 2;
                return true;
            });
        }
        
        if (filteredVariantInventories.length === 0) return;
        
        // Calculate totals for product
        const totalAvailable = filteredVariantInventories.reduce((sum, vi) =>
            sum + (vi.inventory.so_luong_kha_dung || 0), 0
        );
        const totalReserved = filteredVariantInventories.reduce((sum, vi) =>
            sum + (vi.inventory.so_luong_da_dat || 0), 0
        );
        
        productGroups.push({
            product,
            variantInventories: filteredVariantInventories,
            totalAvailable,
            totalReserved
        });
    });
    
    console.log('  ✅ Total product groups:', productGroups.length);
    
    // Pagination on product groups
    const pagination = warehousePagination[warehouseId];
    const totalPages = Math.ceil(productGroups.length / pagination.itemsPerPage);
    const startIdx = (pagination.currentPage - 1) * pagination.itemsPerPage;
    const endIdx = startIdx + pagination.itemsPerPage;
    const paginatedGroups = productGroups.slice(startIdx, endIdx);
    
    document.getElementById('whCount' + warehouseId).textContent = productGroups.length;
    
    if (productGroups.length === 0) {
        console.log('  ❌ No product groups to display');
        tbody.innerHTML = '<tr><td colspan="8" class="text-center">Không có dữ liệu</td></tr>';
        updateWarehousePagination(warehouseId, 0);
        return;
    }
    
    console.log('  🎨 Starting to render', paginatedGroups.length, 'product groups...');
    
    // Render HTML
    let html = '';
    paginatedGroups.forEach((group, groupIdx) => {
        const { product, variantInventories, totalAvailable, totalReserved } = group;
        const groupKey = `wh${warehouseId}-prod${product.id}`;
        
        // Product row (dropdown header)
        html += `
            <tr class="product-row" onclick="toggleVariants('${groupKey}')" style="cursor: pointer;">
                <td class='text-center'>
                    <i class="fas fa-chevron-right toggle-icon" id="icon-${groupKey}" style="transition: transform 0.3s ease; color: var(--primary);"></i>
                </td>
                <td>
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <i class="fas fa-box" style="color: var(--primary);"></i>
                        <strong>${product.ten_san_pham}</strong>
                        <span class="badge bg-info" style="font-size: 0.75rem;">${variantInventories.length} variants</span>
                    </div>
                </td>
                <td class='text-center'><span class='badge bg-success'>${Utils.formatNumber(totalAvailable)}</span></td>
                <td class='text-center'><span class='badge bg-info'>${Utils.formatNumber(totalReserved)}</span></td>
                <td class='text-center'>-</td>
                <td class='text-center'>-</td>
                <td class='text-center'>-</td>
                <td class='text-center'>-</td>
            </tr>
        `;
        
        // Variant rows (collapsed by default)
        variantInventories.forEach((vi, variantIdx) => {
            const { variant, inventory } = vi;
            html += `
                <tr class="variant-row variant-row-${groupKey}" style="display: none;">
                    <td class='text-center'></td>
                    <td style="padding-left: 40px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <i class="fas fa-tag" style="color: var(--gray-500); font-size: 0.85rem;"></i>
                            <div>
                                <div><strong>${product.ten_san_pham}</strong></div>
                                <small class='text-muted'>${variant.ten_hien_thi || variant.ma_sku} (${variant.ma_sku})</small>
                            </div>
                        </div>
                    </td>
                    <td class='text-center'><span class='badge bg-success'>${Utils.formatNumber(inventory.so_luong_kha_dung)}</span></td>
                    <td class='text-center'><span class='badge bg-info'>${Utils.formatNumber(inventory.so_luong_da_dat)}</span></td>
                    <td class='text-center'>${inventory.muc_ton_kho_toi_thieu || 0}</td>
                    <td class='text-center'>${inventory.so_luong_nhap_lai || 0}</td>
                    <td class='text-center'>${Utils.formatDate(inventory.lan_nhap_hang_cuoi)}</td>
                    <td class='text-center'>
                        <button class='btn-sm btn-warning' onclick="event.stopPropagation(); adjustStock('${inventory.id}');" title='Điều chỉnh'>
                            <i class='fas fa-exchange-alt'></i>
                        </button>
                        <button class='btn-sm btn-danger' onclick="event.stopPropagation(); deleteInventory('${inventory.id}');" title='Xóa'>
                            <i class='fas fa-trash'></i>
                        </button>
                    </td>
                </tr>
            `;
        });
    });
    
    tbody.innerHTML = html;
    
    console.log('  ✅ HTML rendered! Total characters:', html.length);
    console.log('  📋 Table rows count:', tbody.querySelectorAll('tr').length);
    console.log('  📦 Product rows count:', tbody.querySelectorAll('.product-row').length);
    console.log('  📊 Variant rows count:', tbody.querySelectorAll('.variant-row').length);
    
    updateWarehousePagination(warehouseId, totalPages);
}

// Toggle variants visibility
function toggleVariants(groupKey) {
    const icon = document.getElementById('icon-' + groupKey);
    const variantRows = document.querySelectorAll('.variant-row-' + groupKey);
    
    const isExpanded = icon.style.transform === 'rotate(90deg)';
    
    if (isExpanded) {
        icon.style.transform = 'rotate(0deg)';
        variantRows.forEach(row => row.style.display = 'none');
    } else {
        icon.style.transform = 'rotate(90deg)';
        variantRows.forEach(row => row.style.display = 'table-row');
    }
}

// Pagination functions
function updateWarehousePagination(warehouseId, totalPages) {
    const pagination = warehousePagination[warehouseId];
    if (!pagination) return;
    
    const prevBtn = document.getElementById('prevBtn' + warehouseId);
    const nextBtn = document.getElementById('nextBtn' + warehouseId);
    const pageNumbersContainer = document.getElementById('pageNumbers' + warehouseId);
    
    if (!prevBtn || !nextBtn || !pageNumbersContainer) return;
    
    prevBtn.disabled = pagination.currentPage === 1;
    nextBtn.disabled = pagination.currentPage >= totalPages || totalPages === 0;
    
    // Generate page numbers
    let pageHTML = '';
    const maxVisible = 7;
    
    if (totalPages <= maxVisible) {
        for (let i = 1; i <= totalPages; i++) {
            pageHTML += `<button class="page-number ${i === pagination.currentPage ? 'active' : ''}" onclick="goToWarehousePage('${warehouseId}', ${i})">${i}</button>`;
        }
    } else {
        pageHTML += `<button class="page-number ${pagination.currentPage === 1 ? 'active' : ''}" onclick="goToWarehousePage('${warehouseId}', 1)">1</button>`;
        
        if (pagination.currentPage > 3) {
            pageHTML += `<span class="page-ellipsis">...</span>`;
        }
        
        let start = Math.max(2, pagination.currentPage - 1);
        let end = Math.min(totalPages - 1, pagination.currentPage + 1);
        
        for (let i = start; i <= end; i++) {
            pageHTML += `<button class="page-number ${i === pagination.currentPage ? 'active' : ''}" onclick="goToWarehousePage('${warehouseId}', ${i})">${i}</button>`;
        }
        
        if (pagination.currentPage < totalPages - 2) {
            pageHTML += `<span class="page-ellipsis">...</span>`;
        }
        
        pageHTML += `<button class="page-number ${pagination.currentPage === totalPages ? 'active' : ''}" onclick="goToWarehousePage('${warehouseId}', ${totalPages})">${totalPages}</button>`;
    }
    
    pageNumbersContainer.innerHTML = pageHTML;
}

function changeWarehousePage(warehouseId, delta) {
    const pagination = warehousePagination[warehouseId];
    if (!pagination) return;
    
    const data = inventoryData.filter(item => item.kho_id == warehouseId);
    const totalPages = Math.ceil(data.length / pagination.itemsPerPage);
    const newPage = pagination.currentPage + delta;
    
    if (newPage >= 1 && newPage <= totalPages) {
        pagination.currentPage = newPage;
        const searchInput = document.querySelector(`.wh-search[data-wh="${warehouseId}"]`);
        const filterSelect = document.querySelector(`.wh-filter[data-wh="${warehouseId}"]`);
        renderWarehouseTable(warehouseId, searchInput?.value || '', filterSelect?.value || '');
    }
}

function goToWarehousePage(warehouseId, page) {
    const pagination = warehousePagination[warehouseId];
    if (!pagination) return;
    
    const data = inventoryData.filter(item => item.kho_id == warehouseId);
    const totalPages = Math.ceil(data.length / pagination.itemsPerPage);
    
    if (page >= 1 && page <= totalPages) {
        pagination.currentPage = page;
        const searchInput = document.querySelector(`.wh-search[data-wh="${warehouseId}"]`);
        const filterSelect = document.querySelector(`.wh-filter[data-wh="${warehouseId}"]`);
        renderWarehouseTable(warehouseId, searchInput?.value || '', filterSelect?.value || '');
    }
}

